{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RanSafeExecutionPayload",
  "type": "object",
  "properties": {
    "action": { "type": "string", "enum": ["AIRGAP_NODE", "REALLOCATE_RESOURCES", "MONITOR_INTENSE"] },
    "target_node_id": { "type": "string" },
    "authorization_token": { "type": "string" },
    "reasoning_summary": { "type": "string" }
  },
  "required": ["action", "target_node_id", "authorization_token", "reasoning_summary"]
}

